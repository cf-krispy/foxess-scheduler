---
// /admin/exportlimit — hidden page for the static Export Limit setting.
// Not linked in the sidebar; navigate to it directly.
import AdminLayout from '../../layouts/AdminLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import ExportLimitCard from '../../components/ExportLimitCard.astro';
---

<AdminLayout title="Export Limit — FoxESS Scheduler">
  <Sidebar />

  <main class="md:ml-[220px] pt-[52px] md:pt-0 px-4 sm:px-6 md:px-10 py-6 md:py-10 max-w-[1020px]">

    <!-- Page heading -->
    <div class="mb-6">
      <h1 class="text-lg font-semibold text-zinc-100 tracking-tight">Export Limit</h1>
      <p class="text-sm text-zinc-500 mt-1">
        Static export limit applied across all schedule groups.
        <a href="/admin/" class="text-zinc-400 underline underline-offset-2 hover:text-zinc-200 ml-2">
          ← Back to Config
        </a>
      </p>
    </div>

    <!-- Not-authenticated notice (hidden by default; shown by JS if 401) -->
    <div id="elc-page-auth-notice" class="hidden bg-zinc-900 border border-zinc-800 rounded-xl p-6 mb-6">
      <p class="text-sm text-zinc-400">
        You are not connected.
        <a href="/admin/" class="text-zinc-200 underline underline-offset-2 hover:text-white ml-1">Connect on the Config page</a>
        to use this feature.
      </p>
    </div>

    <!-- The portable card (hidden until auth check passes) -->
    <div id="elc-wrapper" class="hidden">
      <ExportLimitCard />
    </div>

  </main>
</AdminLayout>

<script>
// Auth pre-check: verify session before showing the card.
// Uses /api/verify-connection (cheap, same endpoint as the main Config page)
// so no extra FoxESS API call is needed.
document.addEventListener('DOMContentLoaded', async () => {
  try {
    const res  = await fetch('/api/verify-connection');
    const data = await res.json();
    if (data.ok) {
      document.getElementById('elc-wrapper')?.classList.remove('hidden');
      return;
    }
  } catch { /* network error — treat as unauthenticated */ }

  // Not authenticated — show the notice; card stays hidden.
  document.getElementById('elc-page-auth-notice')?.classList.remove('hidden');
});
</script>
