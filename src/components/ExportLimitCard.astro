---
// ExportLimitCard — portable, self-contained card for reading/writing the
// inverter's static Export Limit setting (/op/v0/device/setting/get|set).
//
// Drop this component anywhere inside AdminLayout and it works independently.
// It uses `elc-` prefixed IDs to avoid conflicts with other page elements.
// All API calls and state management are in the self-contained IIFE below.
---

<div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6" id="elc-card">

  <!-- Header -->
  <div class="flex items-center justify-between mb-5">
    <h2 class="text-[15px] font-semibold text-zinc-100 tracking-tight">Export Limit</h2>
    <button id="elc-btn-refresh" class="btn btn-secondary btn-sm" title="Reload from inverter">
      <span id="elc-refresh-icon" class="select-none">↻</span>
    </button>
  </div>

  <!-- Loading state -->
  <div id="elc-loading" class="text-sm text-zinc-500">Loading…</div>

  <!-- Error state -->
  <div id="elc-error" class="hidden">
    <p class="text-sm text-red-400 font-medium" id="elc-error-msg">Could not load export limit.</p>
    <button id="elc-btn-retry" class="btn btn-secondary btn-sm mt-3">Retry</button>
  </div>

  <!-- Main content (shown once loaded) -->
  <div id="elc-content" class="hidden">

    <!-- Current value display -->
    <div class="flex items-baseline gap-2 mb-5">
      <span class="text-3xl font-bold font-mono tabular-nums text-zinc-100" id="elc-current-value">—</span>
      <span class="text-sm font-medium text-zinc-500">W</span>
      <span class="text-xs text-zinc-600 ml-1">(current)</span>
    </div>

    <!-- Edit form -->
    <div class="flex items-center gap-3 flex-wrap">
      <div class="flex items-center gap-2">
        <input
          type="number"
          id="elc-input"
          class="bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-100
                 font-mono text-right w-[7rem] focus:outline-none focus:ring-1 focus:ring-zinc-500
                 placeholder-zinc-600"
          min="0"
          max="30000"
          step="100"
          placeholder="e.g. 5000"
        />
        <span class="text-sm font-medium text-zinc-500">W</span>
      </div>
      <button id="elc-btn-save" class="btn btn-primary btn-sm">
        Set Limit
      </button>
    </div>

    <!-- Inline status message (success / error) -->
    <p id="elc-status" class="text-sm mt-3 hidden"></p>

  </div>

</div>

<script>
(function () {
  // ---------------------------------------------------------------------------
  // Helpers
  // ---------------------------------------------------------------------------
  /** @param {string} id */
  function $e(id) { return /** @type {HTMLElement} */ (document.getElementById(id)); }

  function showEl(id)  { const el = $e(id); if (el) el.classList.remove('hidden'); }
  function hideEl(id)  { const el = $e(id); if (el) el.classList.add('hidden');    }

  /**
   * Show the inline status line with an auto-clear after 4 s.
   * @param {string}  msg
   * @param {'success'|'error'} type
   */
  function setStatus(msg, type) {
    const el = $e('elc-status');
    if (!el) return;
    el.textContent  = msg;
    el.className    = `text-sm mt-3 ${type === 'error' ? 'text-red-400' : 'text-emerald-400'}`;
    el.classList.remove('hidden');
    clearTimeout(/** @type {any} */ (el['_timer']));
    el['_timer'] = setTimeout(() => el.classList.add('hidden'), 4000);
  }

  // ---------------------------------------------------------------------------
  // Load
  // ---------------------------------------------------------------------------
  async function load() {
    hideEl('elc-error');
    hideEl('elc-content');
    showEl('elc-loading');
    $e('elc-refresh-icon')?.classList.add('spin');
    $e('elc-btn-refresh')?.setAttribute('disabled', 'disabled');

    try {
      const res  = await fetch('/api/export-limit');
      const data = await res.json();

      if (data && data.ok) {
        $e('elc-current-value').textContent = data.data.value.toLocaleString();
        $e('elc-input').value               = String(data.data.value);
        hideEl('elc-loading');
        showEl('elc-content');
      } else {
        hideEl('elc-loading');
        showEl('elc-error');
        $e('elc-error-msg').textContent = data?.error ?? 'Could not load export limit.';
      }
    } catch (err) {
      hideEl('elc-loading');
      showEl('elc-error');
      $e('elc-error-msg').textContent = `Request failed: ${err instanceof Error ? err.message : String(err)}`;
    } finally {
      $e('elc-refresh-icon')?.classList.remove('spin');
      $e('elc-btn-refresh')?.removeAttribute('disabled');
    }
  }

  // ---------------------------------------------------------------------------
  // Save
  // ---------------------------------------------------------------------------
  async function save() {
    const input = /** @type {HTMLInputElement} */ ($e('elc-input'));
    const raw   = input ? parseInt(input.value, 10) : NaN;

    if (isNaN(raw) || raw < 0 || raw > 30000) {
      setStatus('Value must be 0–30000 W', 'error');
      return;
    }

    const btn = $e('elc-btn-save');
    btn.setAttribute('disabled', 'disabled');
    btn.textContent = 'Saving…';

    try {
      const res  = await fetch('/api/export-limit', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ value: raw }),
      });
      const data = await res.json();

      if (data && data.ok) {
        $e('elc-current-value').textContent = raw.toLocaleString();
        setStatus('Export limit updated', 'success');
      } else {
        setStatus(data?.error ?? 'Save failed', 'error');
      }
    } catch (err) {
      setStatus(`Request failed: ${err instanceof Error ? err.message : String(err)}`, 'error');
    } finally {
      btn?.removeAttribute('disabled');
      btn && (btn.textContent = 'Set Limit');
    }
  }

  // ---------------------------------------------------------------------------
  // Wire up
  // ---------------------------------------------------------------------------
  document.addEventListener('DOMContentLoaded', () => {
    $e('elc-btn-refresh')?.addEventListener('click', load);
    $e('elc-btn-retry')?.addEventListener('click', load);
    $e('elc-btn-save')?.addEventListener('click', save);

    // Allow Enter key in the input to trigger save
    $e('elc-input')?.addEventListener('keydown', (e) => {
      if (/** @type {KeyboardEvent} */ (e).key === 'Enter') save();
    });

    load();
  });
})();
</script>
