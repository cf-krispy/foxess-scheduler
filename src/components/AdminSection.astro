---
// Admin section — OAuth connection status + live inverter telemetry
// All values are loaded / updated by client-side JS in admin/index.astro
---

<section id="section-config" class="section active">

  <!-- ── Card 1: FoxESS account status ──────────────────────────────────── -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 mb-4">
    <h2 class="text-[15px] font-semibold text-zinc-100 mb-5 tracking-tight">FoxESS Account</h2>

    <!-- Checking state — shown on page load while session cookie is verified -->
    <div id="auth-checking" class="flex items-center gap-3 py-1">
      <span class="spin text-lg leading-none text-zinc-500">↻</span>
      <span class="text-sm text-zinc-400">Checking session…</span>
    </div>

    <!-- Not connected state -->
    <div id="auth-disconnected" style="display:none">
      <p class="text-sm text-zinc-400 mb-5 leading-relaxed">
        Enter your FoxESS API key and inverter serial number to connect.
        Credentials are stored only in this browser — nothing is kept on the server.
      </p>

      <form id="connect-form" class="space-y-4">

        <div>
          <label for="cfg-api-key" class="block text-xs font-semibold text-zinc-400 mb-1.5 uppercase tracking-wider">
            API Key
          </label>
          <div class="relative">
            <input id="cfg-api-key" type="password" autocomplete="current-password"
                   class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 pr-16 text-sm text-zinc-100
                          placeholder-zinc-600 focus:outline-none focus:ring-1 focus:ring-zinc-500"
                   placeholder="your-foxess-api-key" />
            <button type="button" id="btn-toggle-api-key"
                    class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-zinc-500 hover:text-zinc-300 px-1 py-0.5">
              Show
            </button>
          </div>
        </div>

        <div>
          <label for="cfg-sn" class="block text-xs font-semibold text-zinc-400 mb-1.5 uppercase tracking-wider">
            Device Serial Number
          </label>
          <input id="cfg-sn" type="text" autocomplete="off"
                 class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-100
                        placeholder-zinc-600 focus:outline-none focus:ring-1 focus:ring-zinc-500 font-mono"
                 placeholder="e.g. H1234567890" />
        </div>

        <button type="submit" id="btn-connect" class="btn btn-primary">
          Save &amp; Connect
        </button>

      </form>
    </div>

    <!-- Connected state -->
    <div id="auth-connected" style="display:none">
      <div class="flex items-center justify-between flex-wrap gap-3">

        <!-- Left: status badge + SN -->
        <div class="flex items-center gap-3">
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-400">
            <span class="w-2 h-2 rounded-full bg-emerald-400 inline-block"></span>
            Connected
          </span>
          <span class="text-zinc-600">·</span>
          <span class="text-sm text-zinc-400">SN: <span id="auth-sn" class="font-mono text-zinc-200"></span></span>
        </div>

        <!-- Right: device detail + disconnect -->
        <div class="flex items-center gap-3 flex-wrap">
          <span id="device-detail" class="flex items-center gap-2 text-sm" style="display:none">
            <span id="device-type" class="font-medium text-zinc-200"></span>
            <span class="text-zinc-700">·</span>
            <span class="text-zinc-500">fw <span id="device-fw" class="text-zinc-300"></span></span>
            <span id="device-bat-separator" class="text-zinc-700">·</span>
            <span id="device-bat-label" class="text-zinc-500">bat <span id="device-bat" class="text-zinc-300"></span></span>
          </span>
          <button id="btn-disconnect" class="btn btn-secondary btn-sm text-red-400 hover:text-red-300">
            Disconnect
          </button>
        </div>

      </div>
    </div>

  </div>

  <!-- ── Quick Settings panel (shown when connected) ─────────────────── -->
  <div id="connection-status" class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 mb-4" style="display:none">

    <div class="flex items-center justify-between mb-5">
      <h2 class="text-[15px] font-semibold text-zinc-100 tracking-tight">Quick Settings</h2>
      <button id="gs-refresh-btn" class="btn btn-secondary btn-sm" title="Reload settings from inverter">
        <span id="gs-refresh-icon" class="text-base leading-none select-none">↻</span>
      </button>
    </div>

    <!-- 2-col on mobile, 4-col on sm+ — Global inverter settings -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">

      <!-- Tile 1: Export Limit -->
      <div class="bg-zinc-950/60 border border-zinc-800/60 rounded-lg p-3">
        <div class="text-[10px] font-semibold uppercase tracking-wider text-zinc-600 mb-2">Export Limit</div>
        <div id="gs-export-limit-loading" class="text-[11px] text-zinc-600">Loading…</div>
        <div id="gs-export-limit-content" class="hidden">
          <div class="text-xl font-bold font-mono tabular-nums text-zinc-100 mb-2" id="gs-export-limit-value">—</div>
          <div class="flex items-center gap-1.5">
            <input type="number" id="gs-export-limit-input" min="0" max="30000" step="100"
                   class="bg-zinc-800 border border-zinc-700 rounded px-2 py-1 text-xs text-zinc-100
                          font-mono w-[5rem] focus:outline-none focus:ring-1 focus:ring-zinc-600 tabular-nums" />
            <span class="text-[10px] text-zinc-500">W</span>
            <button id="gs-export-limit-save" class="btn btn-primary btn-sm">Set</button>
          </div>
          <p id="gs-export-limit-status" class="text-[10px] mt-1.5 hidden"></p>
        </div>
        <div id="gs-export-limit-error" class="hidden">
          <p class="text-[10px] text-red-400 leading-tight" id="gs-export-limit-error-msg">Could not load.</p>
          <button id="gs-export-limit-retry" class="text-[10px] text-zinc-500 hover:text-zinc-300 mt-1 underline">retry</button>
        </div>
      </div>

      <!-- Tile 2: Import Limit -->
      <div class="bg-zinc-950/60 border border-zinc-800/60 rounded-lg p-3">
        <div class="text-[10px] font-semibold uppercase tracking-wider text-zinc-600 mb-2">Import Limit</div>
        <div id="gs-import-limit-loading" class="text-[11px] text-zinc-600">Loading…</div>
        <div id="gs-import-limit-content" class="hidden">
          <div class="text-xl font-bold font-mono tabular-nums text-zinc-100 mb-2" id="gs-import-limit-value">—</div>
          <div class="flex items-center gap-1.5">
            <input type="number" id="gs-import-limit-input" min="0" max="100000" step="100"
                   class="bg-zinc-800 border border-zinc-700 rounded px-2 py-1 text-xs text-zinc-100
                          font-mono w-[5rem] focus:outline-none focus:ring-1 focus:ring-zinc-600 tabular-nums" />
            <span class="text-[10px] text-zinc-500">W</span>
            <button id="gs-import-limit-save" class="btn btn-primary btn-sm">Set</button>
          </div>
          <p id="gs-import-limit-status" class="text-[10px] mt-1.5 hidden"></p>
        </div>
        <div id="gs-import-limit-error" class="hidden">
          <p class="text-[10px] text-red-400 leading-tight" id="gs-import-limit-error-msg">Could not load.</p>
          <button id="gs-import-limit-retry" class="text-[10px] text-zinc-500 hover:text-zinc-300 mt-1 underline">retry</button>
        </div>
      </div>

      <!-- Tile 3: Fault Status -->
      <div class="bg-zinc-950/60 border border-zinc-800/60 rounded-lg p-3">
        <div class="text-[10px] font-semibold uppercase tracking-wider text-zinc-600 mb-2">Fault Status</div>
        <div id="gs-fault-loading" class="text-[11px] text-zinc-600">Loading…</div>
        <div id="gs-fault-content" class="hidden">
          <div class="text-sm font-semibold mt-1" id="gs-fault-value">—</div>
        </div>
        <div id="gs-fault-error" class="hidden">
          <p class="text-[10px] text-red-400 leading-tight" id="gs-fault-error-msg">Could not load.</p>
        </div>
      </div>

      <!-- Tile 4: reserved for future global settings -->
      <div class="bg-zinc-950/60 border border-zinc-800/60 rounded-lg p-3 opacity-30">
        <div class="text-[10px] font-semibold uppercase tracking-wider text-zinc-600">—</div>
      </div>

    </div>
  </div>

</section>
